{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-opengl",
      "type": "shell",
      "command": "C:/Program Files/CodeBlocks/MinGW/bin/g++.exe",
      "args": [
        "main.cpp",
        "mouse.cpp",
        "objetos.cpp",
        "-Iglut/include",
        "-Lglut/lib",
        "-DFREEGLUT_STATIC",
        "-lfreeglut_static",
        "-lopengl32",
        "-lglu32",
        "-lwinmm",
        "-lgdi32",
        "-o",
        "app.exe"
      ],
      "options": {
        "env": {
          "PATH": "C:\\Program Files\\CodeBlocks\\MinGW\\bin;${env:PATH}"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "run-opengl",
      "type": "shell",
      "command": "./app.exe",
      "dependsOn": "build-opengl",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}